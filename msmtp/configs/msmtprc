# Debian 12 location - /etc/msmtprc

# Set default values for accounts
defaults
auth on
tls on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
aliases /etc/aliases

# Mailgun
account mailgun
host smtp.mailgun.org
port 587
from system@theama.me
user system@mg.theama.me
passwordeval "cat /etc/msmtp/secrets/mailgun-password"

# Set a default account
account default: mailgun

# Apprise via Mailrise
account apprise
host mailrise.local.theama.co
port 8025
from %H@local.theama.co
domain %H
set_from_header on
allow_from_override off
auth off
tls off