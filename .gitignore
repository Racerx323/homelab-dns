# DNS specific ignores
*.db
*.zone.bak
*.log
*.pid

# Keep live node-specific Unbound configs private; publish sanitized examples.
Unbound/configs/pihole*.conf
!Unbound/configs/example.conf

# Unbound packaging outputs (source inputs remain tracked).
Unbound/packaging/work/
Unbound/packaging/release/
Unbound/packaging/unbound-pihole-profile/debian/.debhelper/
Unbound/packaging/unbound-pihole-profile/debian/debhelper-build-stamp
Unbound/packaging/unbound-pihole-profile/debian/files
Unbound/packaging/unbound-pihole-profile/debian/unbound-pihole-profile/
*.build
*.buildinfo
*.changes
*.deb

# General ignores
.DS_Store
Thumbs.db

# vexp — repository-local runtime files
/.vexp/*
!/.vexp/.gitattributes
