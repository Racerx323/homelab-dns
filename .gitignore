.vexp/index.db-shm
.vexp/vexp.log
.vexp/daemon.log
.vexp/daemon.sock
.vexp/daemon.pid
.vexp/daemon.pipe
.vexp/mcp.port
.vexp/healthy
.vexp/parent_workspace.json
.vexp/token-savings-report.md
.vexp/index.lock
